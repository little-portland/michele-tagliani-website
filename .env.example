# Copy to .env.local and fill these in after creating a Sanity project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Public client links. The website works with placeholders until these are set.
NEXT_PUBLIC_BOOKING_URL=https://practicebetter.io/
NEXT_PUBLIC_CONTACT_EMAIL=hello@micheletagliani.com
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/michele_tagliani_nutrition/
NEXT_PUBLIC_CLIENT_PORTAL_URL=https://practicebetter.io/

# Contact form email delivery via Resend.
# Create a free Resend account, verify the sending domain, then add these to .env.local and Vercel.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hi@paulonatal.com
CONTACT_FROM_EMAIL="Michele Tagliani Website <hello@micheletagliani.com>"
